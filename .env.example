# Template only — copy to .env (gitignored) and fill in real values.
# Never put real secrets in this file. .env.example is committed to git.

ANTHROPIC_API_KEY=

# SMTP / email delivery. Gmail with app password recommended.
# Issue an app password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# Nikkei integration (Phase 3b). Leave empty to disable Nikkei source.
NIKKEI_USER=
NIKKEI_PASS=
# Browser-use model: claude-sonnet-4-5 (default, better navigation reasoning, more expensive)
# or claude-haiku-4-5 (cheaper, occasional planning misses).
BROWSER_USE_MODEL=claude-sonnet-4-5
