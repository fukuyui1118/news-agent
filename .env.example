# Template only — copy to .env (gitignored) and fill in real values.
# Never put real secrets in this file. .env.example is committed to git.

ANTHROPIC_API_KEY=

# SMTP / email delivery. Gmail with app password recommended.
# Issue an app password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# Nikkei integration (Phase 3b). Leave empty to disable Nikkei source.
NIKKEI_USER=
NIKKEI_PASS=
# Browser-use model: claude-sonnet-4-5 (default, better navigation reasoning, more expensive)
# or claude-haiku-4-5 (cheaper, occasional planning misses).
BROWSER_USE_MODEL=claude-sonnet-4-5

# Inoreader REST API (Phase 9.3). Optional but recommended for the 14 keyword
# tag feeds — gives the article's true publish time instead of Inoreader's
# ingestion timestamp. Without these the agent falls back to the public RSS.
#
# Bootstrap:
#   1. Register an app at https://www.inoreader.com/developers/
#      (redirect URI: urn:ietf:wg:oauth:2.0:oob, scope: read)
#   2. Set INOREADER_APP_ID and INOREADER_APP_SECRET below.
#   3. Run: .venv/bin/python scripts/inoreader_oauth_bootstrap.py
#   4. Paste the printed INOREADER_REFRESH_TOKEN below.
INOREADER_APP_ID=
INOREADER_APP_SECRET=
INOREADER_REFRESH_TOKEN=
